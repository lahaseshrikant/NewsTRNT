# Environment
NODE_ENV=development
PORT=5002

# Database (Neon PostgreSQL)
# keep Neon credentials secure: do not expose them to client-side code
DATABASE_URL='postgresql://admin_api_user:Admin%40NT%23Adi%241875@ep-broad-frost-a1p67iqt-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require'

# JWT
JWT_SECRET=your-jwt-secret-here

# Glass-Breaker Emergency Admin (ONE env-only super-admin for recovery)
# This is the ONLY admin that authenticates via env vars. All others use DB.
GLASS_BREAK_ADMIN_EMAIL=admin@newstrnt.com
GLASS_BREAK_ADMIN_PASSWORD=change-this-to-a-very-strong-password

# Redis
REDIS_URL=redis://localhost:6379

# CORS — admin-frontend origin only
ADMIN_CLIENT_URL=http://localhost:3001

# OpenAI (AI summarization)
OPENAI_API_KEY=sk-your-key-here

# Email (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@newstrnt.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=NewsTRNT <noreply@newstrnt.com>

# Content Engine (service-to-service auth)
# this key is sent as X-API-Key when proxying requests from the admin backend
# to the content engine. It should be the same value as ENGINE_API_KEY
# inside the content-engine service.
CONTENT_ENGINE_API_KEY=your-content-engine-api-key
CONTENT_ENGINE_URL=http://localhost:8000

# Market Data Ingest (scraper auth)
MARKET_INGEST_API_KEY=your-market-ingest-api-key

# Optional: Logging level
LOG_LEVEL=info

# Storage provider (local or r2)
STORAGE_PROVIDER=r2
CDN_DOMAIN=https://cdn.newstrnt.com

# Local storage (used when STORAGE_PROVIDER=local)
LOCAL_STORAGE_DIR=public
STORAGE_UPLOAD_BASE_PATH=media

# Cloudflare R2 (used when STORAGE_PROVIDER=r2)
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_BUCKET=newstrnt-media
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Media pipeline tuning
MAX_FILE_SIZE=26214400
MEDIA_IMAGE_VARIANT_WIDTHS=320,640,1024
MEDIA_IMAGE_VARIANT_FORMATS=webp,avif
MEDIA_PLACEMENT_CROP_RATIOS=16x9,4x3,1x1
MEDIA_PLACEMENT_CROP_WIDTHS=640,1024
MEDIA_VIDEO_POSTER_WIDTH=640
MEDIA_VIDEO_POSTER_HEIGHT=360
MEDIA_ENABLE_RESIZE_FALLBACK=true
MEDIA_COST_PER_GB_USD=0.015
