# Environment
NODE_ENV=development
PORT=5002

# Database (Neon PostgreSQL)
# keep Neon credentials secure: do not expose them to client-side code
DATABASE_URL='postgresql://admin_api_user:Admin%40NT%23Adi%241875@ep-broad-frost-a1p67iqt-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require'

# JWT
JWT_SECRET=your-jwt-secret-here

# Glass-Breaker Emergency Admin (ONE env-only super-admin for recovery)
# This is the ONLY admin that authenticates via env vars. All others use DB.
GLASS_BREAK_ADMIN_EMAIL=admin@newstrnt.com
GLASS_BREAK_ADMIN_PASSWORD=change-this-to-a-very-strong-password

# Redis
REDIS_URL=redis://localhost:6379

# CORS — admin-frontend origin only
ADMIN_CLIENT_URL=http://localhost:3001

# OpenAI (AI summarization)
OPENAI_API_KEY=sk-your-key-here

# Email (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@newstrnt.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=NewsTRNT <noreply@newstrnt.com>

# Content Engine (service-to-service auth)
# this key is sent as X-API-Key when proxying requests from the admin backend
# to the content engine. It should be the same value as ENGINE_API_KEY
# inside the content-engine service.
CONTENT_ENGINE_API_KEY=your-content-engine-api-key
CONTENT_ENGINE_URL=http://localhost:8000

# Market Data Ingest (scraper auth)
MARKET_INGEST_API_KEY=your-market-ingest-api-key

# Optional: Logging level
LOG_LEVEL=info
